          <mxGeometry height="30" width="216" x="330" y="30" as="geometry" />
        </mxCell>
        <mxCell id="yatNVy5yrbhZO3iJoPwh-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#000000;strokeColor=#C73500;" value="---&amp;gt; LED Strip ---&amp;gt;" vertex="1">
          <mxGeometry height="40" width="540" x="149" y="120" as="geometry" />
        </mxCell>
        <mxCell id="yatNVy5yrbhZO3iJoPwh-3" edge="1" parent="1" source="yatNVy5yrbhZO3iJoPwh-1" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="yatNVy5yrbhZO3iJoPwh-2" value="">
